{
  "manifest_version": 3,
  "name": "SmartRead",
  "version": "1.2.0",
  "description": "Premium Arabic/English text rendering engine for Claude, Gemini, and more.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://gemini.google.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": [
        "content/direction.js",
        "content/engine.js",
        "content/typography.js",
        "content/observer.js",
        "content/ui.js",
        "content/input_enhancer.js",
        "content_script.js"
      ],
      "css": ["styles/content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
